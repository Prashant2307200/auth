# Database
DATABASE_URL=postgres://chatty:chatty@localhost:5432/chatty?sslmode=disable

# Redis - required
# Provide Redis connection address (host:port). This must be set in production.
REDIS_ADDRESS=localhost:6379
# Optional: Redis username (leave empty if not used)
REDIS_USERNAME=
# Optional: Redis password (leave empty if not used)
REDIS_PASSWORD=

# Email (MailHog)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_FROM=no-reply@chatty.local

# JWT / tokens
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
REFRESH_TOKEN_SECRET=change-this

# Invite token
INVITE_TOKEN_SECRET=change-this
INVITE_TOKEN_EXPIRY_HOURS=24

# App
HTTP_ADDR=:8080
ENV=dev
