# Copy to .env and export before `make run` (or set in your shell).
# Config file path (required for the binary)
CONFIG_PATH=config/local.yaml

# Core (required by internal/config MustLoad)
ENV=dev
POSTGRES_URI=postgresql://auth_user:auth_password@localhost:5432/auth_db?sslmode=disable
REDIS_ADDRESS=localhost:6379
REDIS_USERNAME=
REDIS_PASSWORD=
REFRESH_TOKEN_SECRET=change-me-to-a-long-random-secret

# Cloudinary (required)
NAME=your-cloudinary-cloud-name
API_KEY=
API_SECRET=

# Optional JWT key paths (defaults: keys/public.pem, keys/private.pem)
# JWT_PUBLIC_KEY_PATH=
# JWT_PRIVATE_KEY_PATH=

# Optional: legacy / future use (access JWT uses RSA files, not this)
# ACCESS_TOKEN_SECRET=
# COOKIE_SECRET=

# Email (Maileroo) - optional, enables password reset and email verification
# MAILEROO_API_KEY=your-maileroo-api-key
# MAILEROO_FROM_EMAIL=noreply@yourdomain.com
# MAILEROO_FROM_NAME=Your App Name
# APP_BASE_URL=http://localhost:3000

# Google OAuth - optional, enables Google SSO
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# Optional: seed DB on startup outside dev (non-prod only)
# SEED_ON_STARTUP=true
